{
  "name": "de-mvp-hackathon",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "init:dev": "scripts/init.sh",
    "dev": "pnpm -r --parallel --filter \"./apps/*\" dev",
    "start": "pnpm -r --parallel --filter \"./apps/*\" start",
    "build": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @repo/db generate",
    "db:migrate": "pnpm --filter @repo/db migrate",
    "db:push": "pnpm --filter @repo/db push",
    "db:studio": "pnpm --filter @repo/db studio",
    "db:seed-demo": "pnpm --filter @repo/db seed-demo",
    "connectors": "pnpm --filter @repo/connectors-runner start",
    "connectors:slack": "pnpm --filter @repo/connectors run:slack",
    "connectors:jira": "pnpm --filter @repo/connectors run:jira",
    "connectors:intercom": "pnpm --filter @repo/connectors run:intercom",
    "connectors:upvoty": "pnpm --filter @repo/connectors run:upvoty",
    "worker:materializer": "pnpm --filter @repo/materializer start",
    "worker:materializer:provision": "pnpm --filter @repo/materializer provision",
    "worker:embedder": "pnpm --filter @repo/embedder start",
    "worker:embedder:provision": "pnpm --filter @repo/embedder provision",
    "eval": "pnpm --filter @repo/eval test",
    "eval:setup": "scripts/eval-setup.sh",
    "prompts:sync": "tsx scripts/sync-prompts.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@langfuse/client": "5.2.0",
    "@langfuse/otel": "5.2.0",
    "@langfuse/tracing": "5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  }
}
