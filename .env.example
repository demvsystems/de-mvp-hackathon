# ──────────────────────────────────────────────────────────────────────────────
# Datastores
# ──────────────────────────────────────────────────────────────────────────────

# Required. Postgres for app + Drizzle migrations (see docker-compose.yml).
DATABASE_URL=postgres://postgres:postgres@localhost:54329/postgres

# Optional per-mode overrides for `pnpm start:mock|demo|full`. If unset, the
# helper script derives `de_mvp_<mode>` on the same server as DATABASE_URL.
# DATABASE_URL_MOCK=postgres://postgres:postgres@localhost:54329/de_mvp_mock
# DATABASE_URL_DEMO=postgres://postgres:postgres@localhost:54329/de_mvp_demo
# DATABASE_URL_FULL=postgres://postgres:postgres@localhost:54329/de_mvp_full

# Required only when running live eval tests (EVAL_LIVE=1).
# DATABASE_URL_EVAL=postgres://postgres:postgres@localhost:54329/postgres_eval

# ──────────────────────────────────────────────────────────────────────────────
# Messaging (NATS)
# ──────────────────────────────────────────────────────────────────────────────

NATS_URL=nats://localhost:4222
# NATS_CLIENT_NAME=messaging

# ──────────────────────────────────────────────────────────────────────────────
# Embeddings — Azure OpenAI
# ──────────────────────────────────────────────────────────────────────────────

AZURE_OPENAI_ENDPOINT=https://aif-demv-hackathon-pari-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional override (e.g. Azure Foundry: https://<resource>.cognitiveservices.azure.com/anthropic).
# ANTHROPIC_BASE_URL=

# LLM_REVIEWER_MODEL=claude-sonnet-4-6
# LLM_REVIEWER_PROMPT_LABEL=production
# LLM_REVIEWER_FILTER=events.topic.>

# Embedding output shape + chunking. Defaults match openai text-embedding-3-small.
EMBEDDING_DIM=1536
# EMBEDDING_MODEL_TAG=openai-small-3
# EMBEDDING_MAX_CHARS=24000

# ──────────────────────────────────────────────────────────────────────────────
# Observability — Langfuse (optional; tracing is skipped if keys are unset)
# ──────────────────────────────────────────────────────────────────────────────

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development
# LANGFUSE_RELEASE=

# ──────────────────────────────────────────────────────────────────────────────
# Eval harness
# ──────────────────────────────────────────────────────────────────────────────

# Set to 1 to run live rubric tests (requires DATABASE_URL_EVAL + AZURE_OPENAI_API_KEY).
# EVAL_LIVE=0
