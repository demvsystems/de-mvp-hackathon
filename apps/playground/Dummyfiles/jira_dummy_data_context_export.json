  },
  "validation": {
    "required_top_level_fields": [
      "metadata",
      "scope",
      "api_domains",
      "endpoints",
      "project_scope",
      "pipeline",
      "pilot_decisions",
      "normalized_example"
    ],
    "required_issue_fields": [
      "id",
      "key",
      "project_id",
      "project_key",
      "type",
      "status",
      "priority",
      "summary",
      "occurred_at"
    ]
  }
}
